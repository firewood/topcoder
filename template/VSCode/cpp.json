	"UnionFind": {
		"prefix": "UnionFind",
		"body": [
			"struct UnionFind {",
			"\tstd::vector<int> _parent;",
			"\tstd::vector<int> _size;",
			"\tUnionFind(int size) : _parent(size, -1), _size(size, 1) { }",
			"\tvoid unite(int a, int b) {",
			"\t\tint ra = root(a), rb = root(b); if (ra == rb) { return; }",
			"\t\tif (_size[ra] < _size[rb]) swap(ra, rb);",
			"\t\t_parent[rb] = ra, _size[ra] += _size[rb];",
			"\t}",
			"\tint root(int a) {",
			"\t\tint p = _parent[a];",
			"\t\tif (p < 0) { return a; }",
			"\t\twhile (_parent[p] >= 0) { p = _parent[p]; }",
			"\t\treturn _parent[a] = p;",
			"\t}",
			"\tint size(int a) { return _size[root(a)]; }",
			"};"
		],
		"description": "UnionFind"
