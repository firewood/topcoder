			"#include <atcoder/fenwicktree>",
			"",
			"template<typename T> struct BIT {",
			"\tint _size;",
			"\tatcoder::fenwick_tree<T> ft;",
			"\tBIT(int size) : _size(size), ft(size) { }",
			"\tvoid add(int pos, T value) { ft.add(pos, value); }",
			"\tT range_sum(int from, int to) { return ft.sum(from, to); }",
			"\tT sum(int pos) { return range_sum(0, pos); }",
			"\tint lower_bound(int64_t value) {",
			"\t\tint left = -1, right = _size;",
			"\t\twhile (right - left > 1) {",
			"\t\t\tint mid = (left + right) / 2;",
			"\t\t\tif (sum(mid + 1) >= value) { right = mid; } else { left = mid; }",
			"\t\t}",
			"\t\treturn right;",
			"\t}",
			"\tvoid set_all(void) { for (int i = 0; i < _size; ++i) { insert(i); } }",
			"\tint size(void) { return int(sum(_size)); }",
			"\tvoid insert(int x) { add(x, 1); }",
			"\tvoid erase(int x) { add(x, -1); }",
			"\tint nth_smallest(int rank) { return (rank >= 1 && rank <= size()) ? lower_bound(rank) : -1; }",
			"\tint nth_biggest(int rank) { return nth_smallest(_size + 1 - rank); }",
			"};",
			"",
