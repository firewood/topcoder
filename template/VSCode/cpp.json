	"Dijkstra": {
		"prefix": "Dijkstra",
		"body": [
			"struct Dijkstra {",
			"\tint64_t size;",
			"\tvector<int64_t> edge_costs;",
			"\tvector<vector<pair<int, int>>> edges;",
			"\tvector<int> min_from;",
			"\tvector<int64_t> min_costs;",
			"",
			"\tDijkstra(int64_t size_) : size(size_), edges(size) { }",
			"",
			"\tvoid build_unidirectional_edges(const std::vector<int64_t>& from, const std::vector<int64_t>& to, std::vector<int64_t> costs = {}) {",
			"\t\tedge_costs = !costs.empty() ? costs : std::vector<int64_t>(from.size(), 1);",
			"\t\tfor (size_t i = 0; i < from.size(); ++i) {",
			"\t\t\tedges[from[i]].emplace_back(make_pair(int(to[i]), int(i)));",
			"\t\t}",
			"\t}",
			"",
			"\tvoid build_bidirectional_edges(const std::vector<int64_t>& from, const std::vector<int64_t>& to, std::vector<int64_t> costs = {}) {",
			"\t\tedge_costs = !costs.empty() ? costs : std::vector<int64_t>(from.size(), 1);",
			"\t\tfor (size_t i = 0; i < from.size(); ++i) {",
			"\t\t\tedges[from[i]].emplace_back(make_pair(int(to[i]), int(i)));",
			"\t\t\tedges[to[i]].emplace_back(make_pair(int(from[i]), int(i)));",
			"\t\t}",
			"\t}",
			"",
			"\tvector<int64_t> &dijkstra(int64_t start) {",
			"\t\tpriority_queue<pair<int64_t, pair<int, int>>, vector<pair<int64_t, pair<int, int>>>, greater<>> q;",
			"\t\tauto push_edges = [&](int64_t cost, int64_t node) {",
			"\t\t\tfor (auto kv : edges[node]) {",
			"\t\t\t\tint64_t next_node = kv.first, next_cost = cost + edge_costs[kv.second];",
			"\t\t\t\tif (next_cost < min_costs[next_node]) {",
			"\t\t\t\t\tmin_from[next_node] = int(node);",
			"\t\t\t\t\tmin_costs[next_node] = next_cost;",
			"\t\t\t\t\tq.emplace(make_pair(next_cost, make_pair(int(next_node), kv.second)));",
			"\t\t\t\t}",
			"\t\t\t}",
			"\t\t};",
			"\t\tmin_from = vector<int>(size, -1);",
			"\t\tmin_costs = vector<int64_t>(size, 1LL << 60);",
			"\t\tmin_costs[start] = 0;",
			"\t\tpush_edges(0, start);",
			"\t\twhile (!q.empty()) {",
			"\t\t\tint64_t cost = q.top().first, node = q.top().second.first, edge = q.top().second.second;",
			"\t\t\tq.pop();",
			"\t\t\tif (cost == min_costs[node]) {",
			"\t\t\t\tpush_edges(cost, node);",
			"\t\t\t}",
			"\t\t}",
			"\t\treturn min_costs;",
			"\t}",
			"",
			"\tvector<int> get_min_path(int from, int to) {",
			"\t\tvector<int> path(1, to);",
			"\t\tint node = to;",
			"\t\twhile (node != from) {",
			"\t\t\tint from_node = min_from[node];",
			"\t\t\tif (from_node < 0) return {};",
			"\t\t\tpath.emplace_back(from_node);",
			"\t\t\tnode = from_node;",
			"\t\t}",
			"\t\treverse(path.begin(), path.end());",
			"\t\treturn path;",
			"\t}",
			"};"
		],
		"description": "Dijkstra"
	},
