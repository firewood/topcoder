{
  indent_width: 1,
  indent_type: "tab",
  insert_space_around_operators: false,
  global_prefix: "",
  declare_group: true,
  append_semicolon: true,
  input_separator: " >> ",
  loop: {
    header: "for (int64_t {loop_var} = 0; {loop_var} < {length}; ++{loop_var}) {",
    footer: "}",
  },
  type: {
    int: "int64_t",
    float: "LD",
    str: "string",
  },
  default: {
    int: "0",
    float: "0.0",
    str: '""',
  },
  arg: {
    int: "int64_t {name}",
    float: "LD {name}",
    str: "string {name}",
    seq: "vector<{type}> {name}",
    "2d_seq": "vector<vector<{type}>> {name}",
  },
  actual_arg: {
    seq: "{name}",
    "2d_seq": "{name}",
  },
  access: {
    seq: "{name}[{index}]",
    "2d_seq": "{name}[{index_i}][{index_j}]",
  },
  declare: {
    int: "int64_t {name}",
    float: "LD {name}",
    str: "string {name}",
    seq: "vector<{type}> {name}",
    "2d_seq": "vector<vector<{type}>> {name}",
  },
  allocate: {
    seq: "{name}.assign({length}, {default});",
    "2d_seq": "{name}.assign({length_i}, vector<{type}>({length_j}));",
  },
  declare_and_allocate: {
    seq: "vector<{type}> {name}({length})",
    "2d_seq": "vector<vector<{type}>> {name}({length_i}, vector<{type}>({length_j}))",
    "2d_outer_only": "vector<vector<{type}>> {name}({length})",
  },
  input: {
    int: "cin >> {name};",
    float: "cin >> {name};",
    str: "cin >> {name};",
  },
}
