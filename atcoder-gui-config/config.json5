{
  theme: 'light',
  defaultUrl: 'https://atcoder.jp/home',
  windowSize: {
    width: 1200,
    height: 900,
  },
  workspaceDir: '~/topcoder/atcoder',
  language: 'cpp',
  createContestDirectory: true,
  buildCommand: {
    cpp: 'g++ -O3 -std=c++23 -DNDEBUG main.cpp -o main',
  },
  preProcess: {
    execOnEachProblemDir: "cp -a ~/topcoder/atcoder/.vscode .",
  },
  postProcess: {
    execOnEachProblemDir: "cp in_1.txt in.txt",
  },
  onEnter: {
    execOnEachProblemDir: "code -r .",
  },
}
